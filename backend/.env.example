# Usada só quando Prisma/Node rodam NO HOST (fora do Docker). Dentro do
# container o docker-compose gera a própria URL via `@postgres:5432`.
# A porta aqui deve ESPELHAR o POSTGRES_PORT do .env da raiz (o compose publica
# `${POSTGRES_PORT}:5432` no host). Em ambiente limpo é 5432; só troque se a
# 5432 estiver ocupada por outro serviço nesta máquina.
DATABASE_URL="postgresql://vigia:vigia@localhost:5432/vigia?schema=public"
JWT_SECRET="troque-por-um-segredo-forte-em-producao"
PORT=3000

# Sessão / refresh token (ver workspace/plans/refresh-token-jwt.md).
# ACCESS_TOKEN_TTL: vida do access token (formato do @nestjs/jwt, ex.: 15m, 1h).
# REFRESH_TOKEN_TTL_DIAS: vida do refresh token, em dias.
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DIAS=30

# Chave do cofre de segredos (RF-004) — cifra o Access Token da Meta em AES-256-GCM.
# 32 bytes em hexadecimal (64 caracteres). Gere com: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=""

# Versão da Graph/Insights API da Meta usada nas chamadas de leitura.
META_API_VERSION="v21.0"
